menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y

if LED_SUBSYSTEM

choice
    prompt "LED blink sleep time"
    default BLINK_SLEEP_TIME_MS_1000
config BLINK_SLEEP_TIME_MS_250
    bool "250ms veryfast"
config BLINK_SLEEP_TIME_MS_500
    bool "500ms fast"
config BLINK_SLEEP_TIME_MS_1000
    bool "1s normal"
config BLINK_SLEEP_TIME_MS_2000
    bool "2s slow"
endchoice

config BLINK_SLEEP_TIME_MS
    int
    default 250 if BLINK_SLEEP_TIME_MS_250
    default 500 if BLINK_SLEEP_TIME_MS_500
    default 1000 if BLINK_SLEEP_TIME_MS_1000
    default 2000 if BLINK_SLEEP_TIME_MS_2000
    default 0
    help
      Time to sleep between toggling the LED
      The value must be between 100 and 5000 milliseconds.

#advanced led settings
menuconfig ADVANCED_LED_SETTINGS
    bool "Advanced LED settings"
    depends on LED_SUBSYSTEM

if ADVANCED_LED_SETTINGS
config LED_BRIGHTNESS
    int "LED brightness (0-100)"
    range 0 100
    default 100

config LED_FADE_DURATION_MS
    int "LED fade duration (ms)"
    range 0 5000
    default 500
endif # ADVANCED_LED_SETTINGS

menu "Expert settings"
    visible if ADVANCED_LED_SETTINGS

config LED_DEBUG
    bool "Enable LED debugging"
    default n

config CUSTOM_LED_PATTERN
    bool "Custom blink pattern"
    default n

endmenu

endif # LED_SUBSYSTEM

config APP_HEARTBEAT_PERIOD_MS
    int "Heartbeat LED period (ms)"
    default 500
    range 100 2000
    help
      Time in milliseconds between LED toggles.
      Increase to slow down the heartbeat, decrease to speed it up.

source "Kconfig.zephyr"
