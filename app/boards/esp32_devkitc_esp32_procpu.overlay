/ {
	aliases
	{
		blueled-onboard = &led2;
		app-led = &led2;
	};

	leds {
		compatible = "gpio-leds";
		led2: led_2 {
			gpios = <&gpio0 2 GPIO_ACTIVE_LOW>;
			label = "Blue LED";
		};

		ledred: led_23 {
			gpios = <&gpio0 23 GPIO_ACTIVE_LOW>;
			label = "Red LED";
		};

		ledgreen: led_22 {
			gpios = <&gpio0 22 GPIO_ACTIVE_LOW>;
			label = "Green LED";
		};

		ledblue: led_1 {
			gpios = <&gpio0 1 GPIO_ACTIVE_LOW>;
			label = "Blue LED External";
		};

	};
};
